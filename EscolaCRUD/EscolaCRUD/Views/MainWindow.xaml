<Window x:Class="EscolaCRUD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏫 Sistema Escola — CRUD de Alunos"
        Height="700" Width="950"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <
            <RowDefinition Height="*"/>    
            <RowDefinition Height="36"/>   
        </Grid.RowDefinitions>

        <!--HEADER -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="🏫" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Sistema Escola" Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Gerenciamento de Alunos · ADO.NET + MySQL"
                               Foreground="#BBDEFB" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CONTENT  -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Painel de formulário (esq) ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                      BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Título do painel -->
                    <TextBlock Text="Dados do Aluno" FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- ID (readonly) -->
                    <TextBlock Text="ID (automático)" Style="{StaticResource LblCaption}"/>
                    <TextBox x:Name="TxtId" Style="{StaticResource InputBox}"
                             IsReadOnly="True" Background="#F8F9FA"
                             Margin="0,0,0,14"
                             ToolTip="Preenchido automaticamente pelo banco"/>

                    <!-- Nome -->
                    <TextBlock Text="NOME COMPLETO" Style="{StaticResource LblCaption}"/>
                    <TextBox x:Name="TxtNome" Style="{StaticResource InputBox}"
                             MaxLength="100" Margin="0,0,0,14"
                             ToolTip="Digite o nome do aluno"/>

                    <!-- Idade -->
                    <TextBlock Text="IDADE" Style="{StaticResource LblCaption}"/>
                    <TextBox x:Name="TxtIdade" Style="{StaticResource InputBox}"
                             MaxLength="3" Margin="0,0,0,24"
                             ToolTip="Somente números"/>

                    <!-- Botões principais -->
                    <Button Content="➕  Inserir Aluno"
                            Style="{StaticResource BtnSuccess}"
                            Margin="0,0,0,8" Height="38"
                            Click="BtnInserir_Click"/>

                    <Button Content="🔄  Atualizar Aluno"
                            Style="{StaticResource BtnWarning}"
                            Margin="0,0,0,8" Height="38"
                            Click="BtnAtualizar_Click"/>

                    <Button Content="🗑️  Remover Aluno"
                            Style="{StaticResource BtnDanger}"
                            Margin="0,0,0,8" Height="38"
                            Click="BtnRemover_Click"/>

                    <Button Content="🧹  Limpar Campos"
                            Style="{StaticResource BtnPrimary}"
                            Height="38" Margin="0,0,0,20"
                            Click="BtnLimpar_Click"/>

                    <!-- Separador -->
                    <Separator Margin="0,0,0,16"/>

                    <!-- Busca por ID (bônus) -->
                    <TextBlock Text="🔍 BUSCAR POR ID" Style="{StaticResource LblCaption}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtBuscaId" Grid.Column="0"
                                 Style="{StaticResource InputBox}"
                                 MaxLength="10"
                                 ToolTip="Digite o ID para buscar"/>
                        <Button Grid.Column="2" Content="Buscar"
                                Style="{StaticResource BtnPrimary}"
                                Height="36" Padding="12,0"
                                Click="BtnBuscar_Click"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Painel da tabela (dir) ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                      BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho da tabela -->
                    <Border Grid.Row="0" CornerRadius="10,10,0,0"
                            Background="{StaticResource BackgroundBrush}"
                            Padding="16,12">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 Lista de Alunos"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{StaticResource PrimaryBrush}"
                                        CornerRadius="12" Margin="10,0,0,0"
                                        Padding="8,2">
                                    <TextBlock x:Name="TxtTotal" Text="0"
                                               Foreground="White" FontSize="11"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button Content="🔃  Atualizar Lista"
                                    Style="{StaticResource BtnPrimary}"
                                    HorizontalAlignment="Right"
                                    Height="32" Padding="12,0"
                                    Click="BtnListar_Click"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="GridAlunos" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEEEEE"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="42"
                              FontSize="13"
                              Background="White"
                              AlternatingRowBackground="#FAFAFA"
                              SelectionChanged="GridAlunos_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"  Value="{StaticResource BackgroundBrush}"/>
                                <Setter Property="Foreground"  Value="{StaticResource TextSecBrush}"/>
                                <Setter Property="FontSize"    Value="11"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                                <Setter Property="Padding"     Value="16,0"/>
                                <Setter Property="Height"      Value="36"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"         Value="16,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"    Binding="{Binding Id}"    Width="70"/>
                            <DataGridTextColumn Header="NOME"  Binding="{Binding Nome}"  Width="*"/>
                            <DataGridTextColumn Header="IDADE" Binding="{Binding Idade}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Rodapé info -->
                    <Border Grid.Row="2" Padding="16,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock Text="💡 Clique em uma linha para selecionar e preencher o formulário"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecBrush}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR  -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <Grid>
                <TextBlock x:Name="TxtStatus"
                           Text="Pronto. Use os botões para gerenciar os alunos."
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecBrush}"/>
                <TextBlock Text="EscolaCRUD · ADO.NET + MySQL · WPF"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#BDBDBD"/>
            </Grid>
        </Border>
    </Grid>
</Window>
